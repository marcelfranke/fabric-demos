/// Product SKU dimension (synthetic) — ZYN ×4 + VEEV ×4 (flavor × pack). Sourced
/// from dim_sku.
table Sku
	lineageTag: e5b2c3d4-0001-4a5b-9c7d-900000000001

	column Id
		dataType: int64
		isHidden
		lineageTag: e5b2c3d4-0011-4a5b-9c7d-900000000011
		summarizeBy: none
		sourceColumn: id

	/// SKU code (natural business key).
	column 'Sku Code'
		dataType: string
		lineageTag: e5b2c3d4-0012-4a5b-9c7d-900000000012
		summarizeBy: none
		sourceColumn: sku_code

	/// Product line (ZYN / VEEV).
	column Program
		dataType: string
		lineageTag: e5b2c3d4-0013-4a5b-9c7d-900000000013
		summarizeBy: none
		sourceColumn: program

	column Flavor
		dataType: string
		lineageTag: e5b2c3d4-0014-4a5b-9c7d-900000000014
		summarizeBy: none
		sourceColumn: flavor

	column Pack
		dataType: string
		lineageTag: e5b2c3d4-0015-4a5b-9c7d-900000000015
		summarizeBy: none
		sourceColumn: pack

	/// Base list price ($) before channel and tax adjustments.
	column 'Base Price'
		dataType: double
		lineageTag: e5b2c3d4-0016-4a5b-9c7d-900000000016
		summarizeBy: none
		sourceColumn: base_price

	partition Sku = entity
		mode: directLake
		source
			entityName: dim_sku
			expressionSource: 'DirectLake - PMI Dynamic Pricing'

