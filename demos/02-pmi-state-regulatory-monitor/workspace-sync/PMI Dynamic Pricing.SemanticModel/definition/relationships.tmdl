relationship PricingSignal_state_State_state
	fromColumn: PricingSignal.State
	toColumn: State.State

relationship PricingSignal_product_code_Program_product_code
	fromColumn: PricingSignal.'Product Code'
	toColumn: Program.'Product Code'

relationship PricingSignal_effective_date_Date_date
	fromColumn: PricingSignal.'Effective Date'
	toColumn: Date.Date

relationship SalesMonthly_state_State_state
	fromColumn: SalesMonthly.State
	toColumn: State.State

relationship SalesMonthly_program_Program_product_code
	fromColumn: SalesMonthly.Program
	toColumn: Program.'Product Code'

relationship SalesMonthly_month_start_Date_date
	fromColumn: SalesMonthly.'Month Start'
	toColumn: Date.Date

relationship SalesMonthly_shop_id_Shop_id
	fromColumn: SalesMonthly.'Shop Id'
	toColumn: Shop.Id

relationship SalesMonthly_sku_id_Sku_id
	fromColumn: SalesMonthly.'Sku Id'
	toColumn: Sku.Id

relationship SalesDaily_state_State_state
	fromColumn: SalesDaily.State
	toColumn: State.State

relationship SalesDaily_program_Program_product_code
	fromColumn: SalesDaily.Program
	toColumn: Program.'Product Code'

relationship SalesDaily_date_Date_date
	fromColumn: SalesDaily.Date
	toColumn: Date.Date

relationship SalesDaily_shop_id_Shop_id
	fromColumn: SalesDaily.'Shop Id'
	toColumn: Shop.Id

relationship SalesDaily_sku_id_Sku_id
	fromColumn: SalesDaily.'Sku Id'
	toColumn: Sku.Id

relationship Forecast_program_Program_product_code
	fromColumn: Forecast.Program
	toColumn: Program.'Product Code'

relationship Forecast_month_start_Date_date
	fromColumn: Forecast.'Month Start'
	toColumn: Date.Date

relationship Shop_city_id_City_id
	fromColumn: Shop.'City Id'
	toColumn: City.Id

