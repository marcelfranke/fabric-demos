model 'PMI Dynamic Pricing'
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["MCP-PBIModeling"]

ref table PricingSignal
ref table State
ref table Program
ref table Date
ref table SalesMonthly
ref table SalesDaily
ref table Forecast
ref table Shop
ref table Sku
ref table City
ref table 'Price Change %'
ref table Elasticity

