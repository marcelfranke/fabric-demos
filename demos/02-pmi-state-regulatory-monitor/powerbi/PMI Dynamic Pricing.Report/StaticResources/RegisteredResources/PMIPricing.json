  "backgroundLight": "#F4F6FA",
  "backgroundNeutral": "#E6EBF2",
  "tableAccent": "#0074C2",
  "good": "#2E9E6B",
  "neutral": "#E8A23D",
  "bad": "#E0523E",
  "maximum": "#E0523E",
  "center": "#E8A23D",
  "minimum": "#2E9E6B",
  "textClasses": {
    "title": {
      "fontFace": "Lato",
      "color": "#00335C",
      "fontSize": 14
    },
    "header": {
      "fontFace": "Lato",
      "color": "#00335C",
      "fontSize": 12
    },
    "label": {
      "fontFace": "Roboto",
      "color": "#14213D",
      "fontSize": 10
    },
    "callout": {
      "fontFace": "Lato",
      "color": "#0074C2",
      "fontSize": 40
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "show": true,
