          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#E6EBF2"
              }
            },
            "show": true,
            "radius": 10
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F4F6FA"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#F4F6FA"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
