model 'European Patents'
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["MCP-PBIModeling"]

ref table Patent
ref table Classification
ref table Applicant
ref table Inventor
ref table Priority
ref table Title
ref table Date

